diff --git a/src/system/function_dispatcher.cpp b/src/system/function_dispatcher.cpp
--- a/src/system/function_dispatcher.cpp
+++ b/src/system/function_dispatcher.cpp
@@
 static void InvalidFunctionTrap(PPCContext& ctx, uint8_t* /*base*/) {
-  REX_FATAL("Call to invalid or unregistered function at guest address 0x{:08X}",
-            ctx.last_indirect_target);
+  REX_FATAL(
+      "Call to invalid or unregistered function at guest address 0x{:08X} "
+      "(lr=0x{:08X}, ctr=0x{:08X}, r3=0x{:08X}, r4=0x{:08X}, r5=0x{:08X}, r6=0x{:08X}, "
+      "r7=0x{:08X}, r8=0x{:08X}, r9=0x{:08X}, r10=0x{:08X}, r11=0x{:08X}, r12=0x{:08X})",
+      ctx.last_indirect_target, static_cast<uint32_t>(ctx.lr), ctx.ctr.u32,
+      ctx.r3.u32, ctx.r4.u32, ctx.r5.u32, ctx.r6.u32, ctx.r7.u32, ctx.r8.u32, ctx.r9.u32,
+      ctx.r10.u32, ctx.r11.u32, ctx.r12.u32);
 }

+static void NullFunctionTrap(PPCContext& ctx, uint8_t* /*base*/) { ctx.r3.u64 = 0; }
+
 PPCFunc* ResolveIndirectFunction(uint32_t guest_address) {
+  if (guest_address == 0) {
+    return &NullFunctionTrap;
+  }
+
+  // Guest data/heap pointers can be observed in optional callback slots during
+  // early bring-up. They are not executable XEX code, so skip them rather than
+  // treating them as missing functions.
+  if (guest_address < 0x80000000u) {
+    return &NullFunctionTrap;
+  }
+
   FunctionDispatcher* dispatcher = GetBoundFunctionDispatcher();
   if (!dispatcher) {
     return &InvalidFunctionTrap;
diff --git a/src/system/xmemory.cpp b/src/system/xmemory.cpp
--- a/src/system/xmemory.cpp
+++ b/src/system/xmemory.cpp
@@
   heaps_.v00000000.AllocFixed(0x0, 0x10000, 0x1000, memory::kMemoryAllocationReserve,
                               !REXCVAR_GET(protect_zero)
                                   ? memory::kMemoryProtectRead | memory::kMemoryProtectWrite
                                   : memory::kMemoryProtectNoAccess);
+  // Some titles read low kernel/shared-memory addresses above the protected zero
+  // page very early during boot. Keep that range mapped and zero-filled so those
+  // accesses behave like normal guest memory instead of becoming host AVs.
+  heaps_.v00000000.AllocFixed(0x00010000, 0x000F0000, 0x1000,
+                              memory::kMemoryAllocationReserve | memory::kMemoryAllocationCommit,
+                              memory::kMemoryProtectRead | memory::kMemoryProtectWrite);
   heaps_.physical.AllocFixed(0x1FFF0000, 0x10000, 0x10000, memory::kMemoryAllocationReserve,
                              memory::kMemoryProtectNoAccess);
