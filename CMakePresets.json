{
  "version": 4,
  "configurePresets": [
    {
      "name": "windows-clang-release",
      "generator": "Ninja",
      "binaryDir": "build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang-cl.exe",
        "CMAKE_CXX_COMPILER": "clang-cl.exe"
      }
    },
    {
      "name": "windows-msvc-release",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "build-msvc",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Release"
      }
    },
    {
      "name": "windows-msvc-recomp-release",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "build-recomp",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Release",
        "SKATE3_ENABLE_RECOMP_LIB": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "clang-release",
      "configurePreset": "windows-clang-release"
    },
    {
      "name": "msvc-release",
      "configurePreset": "windows-msvc-release",
      "configuration": "Release"
    },
    {
      "name": "msvc-recomp-release",
      "configurePreset": "windows-msvc-recomp-release",
      "configuration": "Release"
    }
  ]
}
